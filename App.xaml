<?xml version="1.0" encoding="utf-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:AppGemini.Converters"
             x:Class="AppGemini.App">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:RoleToBubbleAlignConverter x:Key="RoleToBubbleAlignConverter" />
            <converters:RoleToBubbleMarginConverter x:Key="RoleToBubbleMarginConverter" />
            <converters:RoleToBubbleColorConverter x:Key="RoleToBubbleColorConverter" />
            <converters:RoleToTextColorConverter x:Key="RoleToTextColorConverter" />
        </ResourceDictionary>
    </Application.Resources>

</Application>